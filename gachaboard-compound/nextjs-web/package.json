{
  "name": "nextjs-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "env:local": "bash scripts/switch-env.sh local",
    "env:tailscale": "bash scripts/switch-env.sh tailscale",
    "e2e:server": "concurrently -k \"cd sync-server && PORT=5860 npm run start\" \"E2E_TEST_MODE=1 NEXT_PUBLIC_SYNC_WS_URL=ws://localhost:5860 next dev --port 3010\"",
    "test:e2e": "E2E_BASE_URL=http://localhost:3010 npx playwright test",
    "test:e2e:ui": "E2E_BASE_URL=http://localhost:3010 npx playwright test --ui",
    "test:e2e:smoke": "E2E_BASE_URL=http://localhost:3010 npx playwright test e2e/smoke.spec.ts",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@cmpd/assets": "^2.0.0-alpha.21",
    "@cmpd/compound": "^2.0.0-alpha.21",
    "@cmpd/editor": "^2.0.0-alpha.21",
    "@cmpd/state": "^2.0.0-alpha.21",
    "@cmpd/store": "^2.0.0-alpha.21",
    "@cmpd/tlschema": "^2.0.0-alpha.21",
    "@cmpd/utils": "^2.0.0-alpha.21",
    "@cmpd/validate": "^2.0.0-alpha.21",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "7.4.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@twemoji/api": "^17.0.2",
    "browser-fs-access": "^0.38.0",
    "cheerio": "^1.2.0",
    "color-hash": "^2.0.2",
    "date-fns": "^4.1.0",
    "emoji-regex": "^9.2.2",
    "fluent-ffmpeg": "^2.1.3",
    "get-youtube-id": "^1.0.1",
    "idb": "^8.0.3",
    "lodash.debounce": "^4.0.8",
    "minidenticons": "^4.2.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pg": "^8.13.3",
    "pretty-bytes": "^7.1.0",
    "prisma": "7.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^10.0.3",
    "sonner": "^2.0.7",
    "usehooks-ts": "^3.1.1",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/cheerio": "^0.22.35",
    "@types/color-hash": "^2.0.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "20.19.35",
    "@types/pg": "^8.11.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "patch-package": "^8.0.1",
    "puppeteer": "^24.38.0",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  }
}
