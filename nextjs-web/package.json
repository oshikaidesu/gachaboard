{
  "name": "nextjs-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "env:local": "bash scripts/switch-env.sh local",
    "env:tailscale": "bash scripts/switch-env.sh tailscale",
    "e2e:server": "concurrently -k \"cd sync-server && PORT=5860 npm run start\" \"E2E_TEST_MODE=1 NEXT_PUBLIC_SYNC_WS_URL=ws://localhost:5860 next dev --port 3010\"",
    "test:e2e": "npm run seed:e2e && E2E_BASE_URL=http://localhost:3010 npx playwright test -c e2e/playwright.config.ts",
    "test:e2e:ui": "E2E_BASE_URL=http://localhost:3010 npx playwright test -c e2e/playwright.config.ts --ui",
    "test:e2e:smoke": "E2E_BASE_URL=http://localhost:3010 npx playwright test -c e2e/playwright.config.ts smoke.spec.ts",
    "test:e2e:invite": "E2E_BASE_URL=http://localhost:3010 npx playwright test -c e2e/playwright.config.ts invite-flow.spec.ts",
    "test:e2e:tailscale": "npx playwright test -c e2e/playwright.config.ts",
    "screenshots": "npx tsx scripts/check-servers.ts screenshots && mkdir -p ../docs/images/shapes && E2E_BASE_URL=http://localhost:3010 E2E_REUSE_SERVER=1 npx playwright test -c e2e/playwright.config.ts screenshots.spec.ts shapes-screenshots.spec.ts",
    "screenshots:all": "bash scripts/screenshots-all.sh",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "seed:e2e": "npx tsx scripts/check-servers.ts seed && npx tsx scripts/seed-e2e.ts",
    "status": "npx tsx scripts/status.ts",
    "infra:check": "npx tsx scripts/infra-check.ts",
    "start:tailscale": "cd .. && bash scripts/start/tailscale.sh",
    "start:tailscale:reset": "cd .. && bash scripts/start/tailscale.sh --reset",
    "start:local": "cd .. && bash scripts/start/local.sh",
    "start:local:reset": "cd .. && bash scripts/start/local.sh --reset",
    "setup:tailscale-https": "cd .. && bash scripts/setup/tailscale-https.sh",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@cmpd/assets": "^2.0.0-alpha.21",
    "@cmpd/compound": "^2.0.0-alpha.21",
    "@cmpd/editor": "^2.0.0-alpha.21",
    "@cmpd/state": "^2.0.0-alpha.21",
    "@cmpd/store": "^2.0.0-alpha.21",
    "@cmpd/tlschema": "^2.0.0-alpha.21",
    "@cmpd/utils": "^2.0.0-alpha.21",
    "@cmpd/validate": "^2.0.0-alpha.21",
    "@hocuspocus/provider": "^3.4.4",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "7.4.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@twemoji/api": "^17.0.2",
    "@use-gesture/react": "^10.3.1",
    "browser-fs-access": "^0.38.0",
    "cheerio": "^1.2.0",
    "color-hash": "^2.0.2",
    "date-fns": "^4.1.0",
    "emoji-regex": "^9.2.2",
    "fluent-ffmpeg": "^2.1.3",
    "get-youtube-id": "^1.0.1",
    "idb": "^8.0.3",
    "linkify-it": "^5.0.0",
    "lodash.debounce": "^4.0.8",
    "minidenticons": "^4.2.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pg": "^8.13.3",
    "pretty-bytes": "^7.1.0",
    "prisma": "7.4.1",
    "raf-throttle": "^2.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^10.0.3",
    "sonner": "^2.0.7",
    "url-sanitizer": "^2.0.11",
    "usehooks-ts": "^3.1.1",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/cheerio": "^0.22.35",
    "@types/color-hash": "^2.0.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/linkify-it": "^5.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "20.19.35",
    "@types/pg": "^8.11.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "patch-package": "^8.0.1",
    "puppeteer": "^24.38.0",
    "sample-audio-files": "^1.0.7",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "video-media-samples": "^1.0.0"
  },
  "overrides": {
    "yjs": "$yjs"
  }
}
