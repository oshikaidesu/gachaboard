# 統合 .env を使用する場合（推奨）:
#   プロジェクトルートで: npm run setup:env
#   → プロジェクトルートの .env が nextjs-web/.env.local へのシンボリックリンクになります
#
# 従来どおり nextjs-web 単体で使う場合:
#   cp env.local.template .env.local して以下を編集

# ポート（オプション）
# PORT=3000

# Discord OAuth（必須）
DISCORD_CLIENT_ID=REPLACE_WITH_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=REPLACE_WITH_DISCORD_CLIENT_SECRET
SERVER_OWNER_DISCORD_ID=

# NextAuth（必須）
NEXTAUTH_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
NEXTAUTH_URL=http://localhost:18580

# Database（必須）
DATABASE_URL=postgresql://gachaboard:gachaboard@localhost:18581/gachaboard

# S3/MinIO（必須）
S3_BUCKET=my-bucket
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:18583
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:18583
