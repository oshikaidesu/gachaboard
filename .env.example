# ★ 編集するのはここだけ（3つ＋任意2つ）★
# 埋めたら cp .env.example .env して npm run setup:env

# Discord OAuth の Client ID,Secret（Discord Developer Portal → アプリ作成 → OAuth2 から取得）
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# セッション暗号化用。空なら setup:env で自動生成。
NEXTAUTH_SECRET=

# サーバーオーナーの Discord ID。
#設定時はこのユーザーのみワークスペース作成可。空なら全員アクセス可
SERVER_OWNER_DISCORD_ID=

# Tailscale の Auth Key（任意・リモート／start.bat 一発起動用）
# https://login.tailscale.com/admin/settings/keys で Reusable キーを発行
# TAILSCALE_AUTH_KEY=tskey-auth-xxxxx

# --- 以下は自動設定（編集不要・ポート衝突時のみ変更）---
# デフォルトは 18580 番台（他サービスと被らないよう変則的な範囲）
# 3000/5432/8000/9000 等の常用ポートを避けている

# Docker のポートバインド先。127.0.0.1=ローカルのみ、0.0.0.0=Tailscale/LAN からアクセス可
# Tailscale で他端末からアクセスする場合は HOST_BIND=0.0.0.0 に設定
# HOST_BIND=0.0.0.0

# Next.js のポート
PORT=18580
# PostgreSQL のホスト側ポート
POSTGRES_HOST_PORT=18581
# sync-server（Yjs WebSocket）のホスト側ポート
SYNC_SERVER_HOST_PORT=18582
# MinIO API のホスト側ポート
MINIO_API_HOST_PORT=18583
# MinIO 管理コンソールのホスト側ポート
MINIO_CONSOLE_HOST_PORT=18584

# アプリのベース URL。未設定時はリクエストの Host から動的に解決（HTTPS のみなら省略可）
# スクリプト用のフォールバックとして設定してもよい
# NEXTAUTH_URL=https://localhost:18580

# PostgreSQL 接続文字列。POSTGRES_HOST_PORT から自動同期
DATABASE_URL=postgresql://gachaboard:gachaboard@localhost:18581/gachaboard

# S3/MinIO 設定。MINIO_API_HOST_PORT から自動同期
S3_BUCKET=my-bucket
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:18583
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:18583

# sync-server の WebSocket URL。SYNC_SERVER_HOST_PORT から自動同期
NEXT_PUBLIC_SYNC_WS_URL=ws://localhost:18582
SYNC_SERVER_INTERNAL_URL=http://127.0.0.1:18582

# --- メディア変換 ffmpeg（任意）---
# アプリ内設定より優先。未設定なら data/media-encoding.json。
# FFMPEG_VIDEO_BACKEND=cpu|gpu
# FFMPEG_RESOURCE_INTENSITY=light|medium|heavy  （CPU 並列・-threads。2 / 4 / 無制限）
# FFMPEG_OUTPUT_PRESET=light|medium|heavy  （プレビュー品質: 動画CRF・サムネ・MP3・波形）
# FFMPEG_THREAD_LIMIT=4   （ffmpeg -threads、未設定なら負荷段階で 2/4/無制限）
# FFMPEG_OS_PRIORITY=auto|low|normal   （auto=CPU並列「低い」時だけ OS 優先度を下げる）
# レガシー（互換）: FFMPEG_MEDIA_LOAD_PRESET / FFMPEG_MEDIA_ENCODER
# FFMPEG_MAX_CONCURRENT=4
